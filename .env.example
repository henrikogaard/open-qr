# Path to the SQLite file. The Docker image hard-codes /data/openqr.db.
DATABASE_URL=./data/openqr.db

# When behind a reverse proxy that terminates TLS, set these so SvelteKit
# sees the user-facing protocol/host/IP and the Secure cookie flag is emitted.
# PROTOCOL_HEADER=x-forwarded-proto
# HOST_HEADER=x-forwarded-host
# ADDRESS_HEADER=x-forwarded-for

# Email — choose ONE provider. Leave both blank and OTP codes are logged to stdout.
#
# Option A: Resend (https://resend.com)
RESEND_API_KEY=
#
# Option B: SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
#
# "From" address used by whichever provider is active.
MAIL_FROM=
